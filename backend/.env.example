# DevDocs AI Environment Configuration — Cloud Stack
# Copy this file to .env and fill in your credentials

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=DevDocs AI
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# Groq LLM (https://console.groq.com)
# ============================================================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# HuggingFace Inference API (https://huggingface.co/settings/tokens)
# ============================================================================
HF_API_KEY=
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================================================
# Qdrant Cloud (https://cloud.qdrant.io)
# ============================================================================
QDRANT_URL=https://xxx.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=devdocs

# ============================================================================
# Upstash Redis (https://console.upstash.com)
# ============================================================================
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Document Processing Settings
# ============================================================================
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
SUPPORTED_EXTENSIONS=.py,.js,.ts,.java,.go,.md,.tsx,.jsx,.cpp,.c,.h,.rs,.cu,.cuh,.cs,.rb,.swift,.kt,.scala,.r,.m,.sh,.yaml,.yml,.json,.toml,.sql

# ============================================================================
# RAG Settings
# ============================================================================
RETRIEVAL_TOP_K=5
RAG_CONTEXT_WINDOW=4000
MAX_CONTEXT_CHARS=2000

# ============================================================================
# Cache Settings
# ============================================================================
ENABLE_CACHING=true
CACHE_TTL_EMBEDDINGS=86400
CACHE_TTL_RESPONSES=3600

# ============================================================================
# Performance Settings
# ============================================================================
ENABLE_SMART_CHUNKING=true

# ============================================================================
# API Settings
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://devdocs-ai.vercel.app
